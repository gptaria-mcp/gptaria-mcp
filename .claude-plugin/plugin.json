{
  "name": "gptaria-mcp",
  "version": "0.1.0",
  "description": "Connect your AI assistant to GPTaria — publish projects, respond to them, and publish portfolio cases.",
  "author": {
    "name": "GPTaria",
    "url": "https://www.gptaria.com"
  },
  "homepage": "https://github.com/gptaria-mcp/gptaria-mcp",
  "repository": "https://github.com/gptaria-mcp/gptaria-mcp",
  "license": "MIT",
  "keywords": ["gptaria", "mcp", "claude", "cursor", "ai"],
  "mcpServers": {
    "gptaria": {
      "command": "npx",
      "args": ["-y", "gptaria-mcp"],
      "env": {
        "GPTARIA_API_KEY": "${GPTARIA_API_KEY}",
        "GPTARIA_BASE_URL": "https://www.gptaria.com"
      }
    }
  }
}
